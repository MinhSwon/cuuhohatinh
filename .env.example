PORT=5000
CLIENT_ORIGINS=http://localhost:5000,https://ten-mien-cua-ban.com
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=8h
API_RATE_LIMIT=5000
AUTH_RATE_LIMIT=100
PUBLIC_WRITE_RATE_LIMIT=200
SEED_ADMIN_PASSWORD=replace-admin-demo-password
SEED_RESCUE_PASSWORD=replace-rescue-demo-password
SEED_CITIZEN_PASSWORD=replace-citizen-demo-password

# Local PostgreSQL through pgAdmin/PostgreSQL.
# Replace password, host, port, and database name with your setup.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/flood_rescue

# Use PGSSL=true only on hosting providers that require SSL.
PGSSL=false
